{
  // ─── clangd (C++ language server) ────────────────────────────────────────
  "clangd.path": "clangd",
  "clangd.arguments": [
    "--compile-commands-dir=${workspaceFolder}/build",
    "--background-index",
    "--clang-tidy",
    "--header-insertion=iwyu",
    "--completion-style=detailed",
    "--inlay-hints=true",
    "--fallback-style=Google",
    "-j=4"
  ],
  // Tắt IntelliSense của ms-cpptools để không conflict với clangd
  "C_Cpp.intelliSenseEngine": "disabled",
  "C_Cpp.autocomplete": "disabled",
  "C_Cpp.errorSquiggles": "disabled",

  // ─── CMake Tools ─────────────────────────────────────────────────────────
  "cmake.buildDirectory": "${workspaceFolder}/build",
  "cmake.generator": "Ninja",
  "cmake.configureArgs": [
    "-DCMAKE_BUILD_TYPE=Debug",
    "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
    "-DDEEPSTREAM_DIR=/opt/nvidia/deepstream/deepstream"
  ],
  "cmake.copyCompileCommands": "${workspaceFolder}/build/compile_commands.json",
  "cmake.parallelJobs": 0,
  "cmake.buildArgs": ["-j0"],
  "cmake.statusbar.advanced": {
    "launch": { "visibility": "compact" },
    "debug": { "visibility": "compact" },
    "build": { "visibility": "compact" }
  },

  // ─── Editor ──────────────────────────────────────────────────────────────
  "editor.formatOnSave": true,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.rulers": [100],
  "editor.detectIndentation": false,
  "[cpp]": {
    "editor.defaultFormatter": "xaver.clang-format",
    "editor.formatOnSave": true
  },
  "[c]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },

  // ─── File associations ────────────────────────────────────────────────────
  "files.associations": {
    "*.hpp": "cpp",
    "*.cpp": "cpp",
    "*.h": "c",
    "*.cc": "cpp",
    "*.cxx": "cpp",
    "*.yml": "yaml",
    "*.yaml": "yaml",
    "CMakeLists.txt": "cmake",
    "*.cmake": "cmake"
  },

  // ─── File explorer exclude ────────────────────────────────────────────────
  "files.exclude": {
    "**/.git": true,
    "**/build/_deps": true,
    "**/build/CMakeFiles": true
  },
  "search.exclude": {
    "**/build": true,
    "**/dev/logs": true,
    "**/dev/rec": true
  },

  // ─── YAML (configs) ───────────────────────────────────────────────────────
  "yaml.schemas": {},
  "yaml.format.enable": true,
  "yaml.format.singleQuote": false
}
